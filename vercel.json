{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/live-events", "destination": "/live-events.html" },
    { "source": "/camera-rental", "destination": "/camera-rental.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
